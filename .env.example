# ---- Supabase (project: fobturaedgcxangbaxdh) ----
NEXT_PUBLIC_SUPABASE_URL=https://fobturaedgcxangbaxdh.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-publishable-key

# Service role — SERVER ONLY. Used by admin user-provisioning route. Never expose to client.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Synthetic email domain for username-based janitor logins
NEXT_PUBLIC_LOGIN_EMAIL_DOMAIN=sawai.local

# ---- Web Push (VAPID) — generate with: npm run gen:vapid ----
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@sawai.local

